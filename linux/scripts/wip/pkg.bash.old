#!/usr/bin/env bash

while IFS= read -r fn; do
    builtin unset -f "${fn}"
done < <(builtin compgen -A function)

builtin unalias -a

export LC_ALL='C'
export PATH='/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin'

set -euo pipefail

readonly -a PKG_OPTS=(
    check
    clean
    commands
    completion
    depends
    download
    dump
    files
    info
    install
    reinstall
    rdepends
    remove
    repo
    search
    update
    upgrade
)

usage () {
    local reset=$'\033[0m'       # reset
    local bold=$'\033[1m'        # bold
    local italic=$'\033[3m'      # italic
    local underline=$'\033[4m'   # underline
    local reverse=$'\033[7m'     # reverse
    local dim=$'\033[2m'         # dim
    local violet=$'\033[35m'     # violet
    local indigo=$'\033[34m'     # indigo
    local blue=$'\033[94m'       # blue
    local green=$'\033[32m'      # green
    local yellow=$'\033[33m'     # yellow
    local orange=$'\033[91m'     # orange
    local red=$'\033[31m'        # red
    local fmt="${reverse}${bold}"

    /usr/bin/cat << EOF
${fmt}# Usage${reset}
$ $(/usr/bin/basename "${0}") <option> [args...]
${fmt}# Maintenance${reset}
check                 Displays package manager and environment diagnostics.
clean                 Removes the package manager's downloaded package cache.
completion            Prints bash completion script.
dump                  Exports installed packages as NAME<TAB>VERSION to /home/pkg-dump-<manager>.txt and stdout.
update                Refreshes package metadata and repository indexes.
upgrade               Upgrades all installed packages to the latest available versions.
${fmt}# Query${reset}
commands  <pkg>       Lists executable commands installed by the package.
depends   <pkg>       Lists the package's direct dependencies.
files     <pkg>       Lists all non-directory files installed by the package.
info      <pkg>       Displays package metadata and details.
rdepends  <pkg>       Lists installed packages that depend on the package.
repo                  Displays configured package repositories
search    <query>     Searches package names and descriptions.
${fmt}# Operations${reset}
download  <pkg(s)>    Downloads one or more packages without installing them.
install   <pkg(s)>    Installs one or more packages.
reinstall <pkg(s)>    Installs one or more packages.
remove    <pkg(s)>    Removes one or more installed packages.
EOF
}

die () {
    usage
    builtin exit 1
}

elevate() {
    if [[ ${EUID} -eq 0 ]]; then
        readonly ELEVATE=""
        return
    fi

    local tool

    for tool in sudo sudo-rs doas; do
        [[ -x /usr/bin/${tool} ]] || continue
        readonly ELEVATE="/usr/bin/${tool}"
        return
    done

    builtin printf 'No supported privilege elevation tool found.\n' >&2
    builtin exit 1
}

pkg_detect () {
    for tool in apt-get dnf pacman; do
        [[ -x /usr/bin/${tool} ]] || continue
        readonly PKG="${tool}"
        builtin return
    done

    builtin printf 'No supported package manager found.\n' >&2
    builtin exit 1
}

pkg_check() {
    source /etc/os-release
    builtin printf 'distro id: %s\n' "${ID}"

    builtin printf 'package manager: %s\n' "${PKG}"

    if [[ ${EUID} -eq 0 ]]; then
        builtin printf 'running as root: %s\n' yes
    else
        builtin printf 'running as root: %s\n' no
    fi

    builtin printf 'elevation tool: %s\n' "${ELEVATE:+${ELEVATE##*/}}${ELEVATE:-none}"

    if [[ -x /usr/bin/curl || -x /usr/bin/wget ]]; then
        builtin printf 'download tool: %s\n' yes
    else
        builtin printf 'download tool: %s\n' no
    fi
}

pkg_clean () {
    case "${PKG}" in
        apt-get) ${ELEVATE} /usr/bin/apt-get clean ;;
        dnf)     ${ELEVATE} /usr/bin/dnf clean all ;;
        pacman)  ${ELEVATE} /usr/bin/pacman -Scc   ;;
    esac
}

pkg_commands () {
    local pkg="${1:-}"

    [[ -n "${pkg}" ]] || die

    local IFS=":"
    local -a path_dirs

    builtin read -r -a path_dirs <<< "${PATH}"

    pkg_files "${pkg}" | while IFS= read -r file; do
        [[ -f "${file}" && -x "${file}" ]] || continue
        for dir in "${path_dirs[@]}"; do
            [[ "${file}" == "${dir}/"* ]] || continue
            cmd="${file##*/}"
            builtin printf '%s\t%s\n' "${cmd}" "${file}"
            break
        done
    done | /usr/bin/awk -F '\t' '
            {
                rows[NR] = $0
                if (length($1) > max)
                    max = length($1)
            }
            END {
                for (i = 1; i <= NR; i++) {
                    split(rows[i], f, "\t")
                    printf "%-*s %s\n", max, f[1], f[2]
                }
            }'
}

pkg_completion() {
    local commands="${PKG_OPTS[*]}"

    /usr/bin/cat << EOF
_pkg_comp()
{
    local cur

    COMPREPLY=()
    cur=\${COMP_WORDS[COMP_CWORD]}

    if (( COMP_CWORD == 1 )); then
        COMPREPLY=(\$(compgen -W '${commands}' -- "\${cur}"))
    fi
}

complete -F _pkg_comp pkg.bash
EOF
}

pkg_download () {
    [[ $# -ge 1 ]] || die

    case "${PKG}" in
        apt-get)
            ${ELEVATE} /usr/bin/apt-get download "${@}"
            ;;
        dnf)
            ${ELEVATE} /usr/bin/dnf download "${@}"
            ;;
        pacman)
            ${ELEVATE} /usr/bin/pacman -Sw --cachedir "${PWD}" "${@}"
            ;;
    esac
}

pkg_depends() {
    local pkg="${1:-}"

    [[ -n "${pkg}" ]] || die

    case "${PKG}" in
        apt-get) /usr/bin/apt-cache depends "${pkg}" | /usr/bin/grep -E '^[[:space:]]*(Depends|PreDepends):' | /usr/bin/cut -d: -f2- | /usr/bin/xargs -n1 ;;
        dnf)     /usr/bin/dnf5 --quiet repoquery --providers-of=requires --queryformat '%{name}\n' "${pkg}" ;;
        pacman)  /usr/bin/pacman -Si "${pkg}" | /usr/bin/grep '^Depends On' | /usr/bin/cut -d: -f2- | /usr/bin/xargs -n1 ;;
    esac | /usr/bin/sort -u | /usr/bin/xargs
}

pkg_rdepends() {
    local pkg="${1:-}"

    [[ -n "${pkg}" ]] || die

    case "${PKG}" in
        apt-get) /usr/bin/apt-cache rdepends "${pkg}" | /usr/bin/grep '^  ' | /usr/bin/xargs -n1 ;;
        dnf)     /usr/bin/dnf5 --quiet repoquery --installed --whatrequires "${pkg}" --queryformat '%{name}\n' ;;
        pacman)  /usr/bin/pactree --reverse --unique --depth 1 "${pkg}" | /usr/bin/tail -n +2 ;;
    esac | /usr/bin/sort -u | /usr/bin/xargs
}

pkg_dump () {
    local output="/home/pkg-dump-${PKG}.txt"
    local timestamp="$(/usr/bin/date '+%Y%m%d%H%M%S')"
    local command

    {
        case "${PKG}" in
            apt-get)
                command="/usr/bin/dpkg-query --show --showformat='\${Package}\t\${Version}\n'"
                builtin printf '#%s | %s\n' "${timestamp}" "${command}"
                /usr/bin/dpkg-query --show --showformat='${Package}\t${Version}\n' | /usr/bin/sort
                ;;
            dnf)
                command="/usr/bin/rpm --query --all --queryformat='%{NAME}\t%{VERSION}\n'"
                builtin printf '#%s | %s\n' "${timestamp}" "${command}"
                /usr/bin/rpm --query --all --queryformat='%{NAME}\t%{VERSION}\n' | /usr/bin/sort
                ;;
            pacman)
                command="/usr/bin/pacman --query --native | /usr/bin/awk '{ print \$1 \"\t\" \$2 }'"
                builtin printf '#%s | %s\n' "${timestamp}" "${command}"
                /usr/bin/pacman --query --native | /usr/bin/awk '{ print $1 "\t" $2 }' | /usr/bin/sort
                ;;
            *)
                builtin printf 'Unsupported package manager: %s\n' "${PKG}" >&2
                builtin return 1
                ;;
        esac
    } | ${ELEVATE} /usr/bin/tee "${output}"
}

pkg_info () {
    local pkg="${1:-}"

    [[ -n "${pkg}" ]] || die

    case "${PKG}" in
        apt-get) /usr/bin/apt-cache show "${pkg}" ;;
        dnf)     /usr/bin/dnf info "${pkg}" ;;
        pacman)  /usr/bin/pacman -Si "${pkg}" ;;
    esac
}

pkg_files () {
    local pkg="${1:-}"

    [[ -n "${pkg}" ]] || die

    case "${PKG}" in
        apt-get)
            /usr/bin/dpkg -L "${pkg}"
            ;;
        dnf)
            /usr/bin/rpm -ql "${pkg}"
            ;;
        pacman)
            /usr/bin/pacman --query --list "${pkg}" | /usr/bin/awk '{ print $2 }'
            ;;
    esac | while IFS= read -r path; do [[ ! -d "${path}" ]] && printf '%s\n' "${path}"; done | /usr/bin/sort
}

pkg_install () {
    [[ $# -ge 1 ]] || die

    case "${PKG}" in
        apt-get) ${ELEVATE} /usr/bin/apt-get install "${@}" ;;
        dnf)     ${ELEVATE} /usr/bin/dnf install "${@}" ;;
        pacman)  ${ELEVATE} /usr/bin/pacman --sync "${@}" ;;
    esac
}

pkg_reinstall () {
    [[ $# -ge 1 ]] || die

    case "${PKG}" in
        apt-get) ${ELEVATE} /usr/bin/apt-get install --reinstall "${@}" ;;
        dnf)     ${ELEVATE} /usr/bin/dnf reinstall "${@}" ;;
        pacman)  ${ELEVATE} /usr/bin/pacman --sync "${@}" ;;
    esac
}

pkg_remove () {
    [[ $# -ge 1 ]] || die

    case "${PKG}" in
        apt-get) ${ELEVATE} /usr/bin/apt-get remove -y "${@}" ;;
        dnf)     ${ELEVATE} /usr/bin/dnf remove "${@}" ;;
        pacman)  ${ELEVATE} /usr/bin/pacman -R "${@}" ;;
    esac
}

pkg_repo () {
    case "${PKG}" in
        apt-get)/usr/bin/grep -h '^URIs:' /etc/apt/sources.list.d/*.sources | /usr/bin/cut -d: -f2- | /usr/bin/xargs -n1 | /usr/bin/sort -u ;;
        dnf) /usr/bin/dnf5 --quiet repo info | /usr/bin/grep 'Base URL' | /usr/bin/sed 's/^[[:space:]]*Base URL[[:space:]]*:[[:space:]]*//' | /usr/bin/cut -d' ' -f1 | /usr/bin/sort -u ;;
        pacman) /usr/bin/pacman-conf --repo-list | while IFS= builtin read -r repo; do /usr/bin/pacman-conf --repo="${repo}" Server | /usr/bin/head -n1; done | /usr/bin/sort -u ;;
    esac
}

pkg_search () {
    [[ $# -eq 1 ]] || die

    case "${PKG}" in
        apt-get) /usr/bin/apt-cache search "${1}" ;;
        dnf)     /usr/bin/dnf search "${1}" ;;
        pacman)  /usr/bin/pacman -Ss "${1}" ;;
    esac
}

pkg_update () {
    case "${PKG}" in
        apt-get) ${ELEVATE} /usr/bin/apt-get update ;;
        dnf)     ${ELEVATE} /usr/bin/dnf check-update ;;
        pacman)  ${ELEVATE} /usr/bin/pacman -Sy ;;
    esac
}

pkg_upgrade () {
    case "${PKG}" in
        apt-get) ${ELEVATE} /usr/bin/apt-get upgrade ;;
        dnf)     ${ELEVATE} /usr/bin/dnf upgrade ;;
        pacman)  ${ELEVATE} /usr/bin/pacman -Syu ;;
    esac
}

pkg_tasks () {
    local cmd="${1:-}"
    [[ -n "${cmd}" ]] || die
    shift
    case "${cmd}" in
        check)      pkg_check ;;
        clean)      pkg_clean ;;
        commands)   pkg_commands "${@}" ;;
        completion) pkg_completion ;;
        depends)    pkg_depends "${@}" ;;
        download)   pkg_download "${@}" ;;
        dump)       pkg_dump ;;
        files)      pkg_files "${@}" ;;
        info)       pkg_info "${@}" ;;
        install)    pkg_install "${@}" ;;
        reinstall)  pkg_reinstall "${@}" ;;
        rdepends)   pkg_rdepends "${@}" ;;
        remove)     pkg_remove "${@}" ;;
        repo)       pkg_repo ;;
        search)     pkg_search "${@}" ;;
        update)     pkg_update ;;
        upgrade)    pkg_upgrade ;;
        *)          die ;;
    esac
}

main() {
    [[ $# -ge 1 ]] || die
    elevate
    pkg_detect
    pkg_tasks "${@}"
}

main "${@}"
