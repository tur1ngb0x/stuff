{
    // Enabled
    "BraveAIChatEnabled": false,
    "BraveP3AEnabled": false,
    "BraveStatsPingEnabled": false,
    "BraveWebDiscoveryEnabled": false,
    "BravePlaylistEnabled": false,
    "EmailAliasesEnabled": false,

    // Disabled
    "BraveRewardsDisabled": true,
    "BraveNewsDisabled": true,
    "BraveTalkDisabled": true,
    "BraveVPNDisabled": true,
    "BraveWalletDisabled": true,
    "TorDisabled": true,

    // Other
    "DefaultBraveHttpsUpgradeSetting": 2
}

// https://support.brave.app/hc/en-us/articles/360039248271-Group-Policy
// https://github.com/brave/brave-core/tree/master/components/policy/resources/templates/policy_definitions
// https://github.com/brave/brave-core/tree/master/components/policy/resources/templates/policy_definitions/BraveSoftware

// save /tmp/brave.txt
// /usr/bin/curl -s 'https://api.github.com/repos/brave/brave-core/contents/components/policy/resources/templates/policy_definitions/BraveSoftware' | /usr/bin/grep -i '"name": ' | tee /tmp/brave.txt

// save /tmp/brave.json
// /usr/bin/curl -s https://api.github.com/repos/brave/brave-core/contents/components/policy/resources/templates/policy_definitions/BraveSoftware | /usr/bin/jq --indent 4 '[ .[] | select(.name | endswith(".yaml")) | select(.name != ".group.details.yaml") | .name ] | map(sub("\\.yaml$"; "")) | map({ (.): "VALUE" }) | add' | tee /tmp/brave.json

// save /tmp/brave.json with comments
// /usr/bin/curl -s https://api.github.com/repos/brave/brave-core/contents/components/policy/resources/templates/policy_definitions/BraveSoftware | /usr/bin/jq -r '[ .[] | select(.name | endswith(".yaml")) | select(.name != ".group.details.yaml") ] | "{\n" + (map("    // " + .html_url + "\n" + "    \"" + (.name | sub("\\.yaml$"; "")) + "\": \"VALUE\"") | join(",\n\n")) + "\n}"'

// install local brave.json
// sudo install -v -D -o root -g root -m 644 ./brave.json /etc/brave/policies/managed/brave.json
