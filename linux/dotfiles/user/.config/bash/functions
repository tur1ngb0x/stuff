ls() {
    LC_ALL=C /usr/bin/ls \
        --almost-all \
        --color=always \
        --format=verbose \
        --group-directories-first \
        --indicator-style=file-type \
        --quoting-style=shell \
        --time-style=+%Y%m%d-%H%M%S \
        "$@" |
    /usr/bin/awk 'NR==1 {next} {printf "%s\t%s:%s\t%s\t", $1,$3,$4,$6; for(i=7;i<=NF;i++) if($i=="->"){printf "@"; break} else printf "%s%s",(i>7?" ":""),$i; print ""}' | \
    /usr/bin/column --table --separator $'\t' --output-separator ' ' -N PERMS,USER:GROUP,MODIFIED,ITEMS
}

cd() {
    if [[ $# -eq 0 ]]; then
        builtin cd "${HOME}" || builtin return
    elif [[ $# -eq 1 ]]; then
        builtin cd "${1}" || builtin return
        if [ "$(/usr/bin/find . -mindepth 1 -maxdepth 1 -printf '.' | /usr/bin/head -c 50 | /usr/bin/wc -c)" -lt 50 ]; then
            ls .
        fi
    else
        printf 'too many arguments\n'
    fi
}

testscript() {
    local SCRIPT_NAME="${1:?Enter script name}"

    if [[ ! "${SCRIPT_NAME}" =~ ^[A-Za-z0-9]+$ ]]; then
        printf "Error: only 0-9 and A-Z a-z allowed"
        return 1
    fi

    local SCRIPT_NAME="${SCRIPT_NAME}.bash"
    local SCRIPT_DIR="${HOME}/src/stuff/linux/scripts"

    install -v -D -m 0755 /dev/null "${SCRIPT_DIR}/${SCRIPT_NAME}"
    code "${SCRIPT_DIR}/${SCRIPT_NAME}"
    echo "Run the script with bash ${SCRIPT_DIR}/${SCRIPT_NAME}"
}

vscode-root () {
    if [[ $# -eq 0 ]]; then
        printf "usage: vscode-root <file(s)/folder(s)>\n"
        return
    fi

    sudo rm -rf /tmp/vscode-root
    sudo mkdir -p /tmp/vscode-root/data/User
    sudo mkdir -p /tmp/vscode-root/extensions
    sudo cp -fv /home/user/.config/Code/User/settings.json /tmp/vscode-root/data/User/settings.json

    sudo code \
        --disable-chromium-sandbox \
        --disable-extensions \
        --locale en-US \
        --log off \
        --new-window \
        --no-sandbox \
        --sync off \
        --user-data-dir /tmp/vscode-root/data \
        --extensions-dir /tmp/vscode-root/extensions \
        "${@}"
}

