path() {
    local dir EXEC MODIFIED EXISTS
    IFS=':' read -r -a PATHS <<< "${PATH}"

    for dir in "${PATHS[@]}"; do
        if [ -d "${dir}" ]; then
            EXISTS=Y
            read EXEC MODIFIED < <(find -L "${dir}" -mindepth 1 -maxdepth 1 -printf '%T@ ' \( -type f -o -type l \) -executable -printf '1\n' -o -printf '0\n' 2>/dev/null | awk '{ if ($1>max) max=$1; if ($2==1) exec++ } END { printf "%d %f\n", exec, max }')
            MODIFIED=$(date -d "@${MODIFIED:-0}" "+%Y-%m-%d %H:%M:%S")
        else
            EXISTS=N; MODIFIED="-"; EXEC=0
        fi

        printf "%s\t%s\t%s\t%s\n" "${dir}" "${EXISTS}" "${MODIFIED}" "${EXEC}"
    done | column --table --separator $'\t' -N PATH,EXISTS,MODIFIED,EXECUTABLES -R 4
}

path() {
    local dir EXEC MODIFIED EXISTS PRIORITY=1
    IFS=':' read -r -a PATHS <<< "${PATH}"

    for dir in "${PATHS[@]}"; do
        if [ -d "${dir}" ]; then
            EXISTS=Y
            read EXEC MODIFIED < <(find -L "${dir}" -mindepth 1 -maxdepth 1 -printf '%T@ ' \( -type f -o -type l \) -executable -printf '1\n' -o -printf '0\n' 2>/dev/null | awk '{ if ($1>max) max=$1; if ($2==1) exec++ } END { printf "%d %f\n", exec, max }')
            MODIFIED=$(date -d "@${MODIFIED:-0}" "+%Y-%m-%d %H:%M:%S")
            printf "%s\t%s\t%s\t%s\t%s\n" "${dir}" "${EXISTS}" "${PRIORITY}" "${MODIFIED}" "${EXEC}"
            ((PRIORITY++))
        else
            EXISTS=N; MODIFIED="-"; EXEC=0
            printf "%s\t%s\t%s\t%s\t%s\n" "${dir}" "${EXISTS}" "-" "${MODIFIED}" "${EXEC}"
        fi
    done | column --table --separator $'\t' -N PATH,EXISTS,PRIORITY,MODIFIED,EXECUTABLES -R 3,5
}
